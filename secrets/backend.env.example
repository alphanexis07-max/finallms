############################################
# Backend (FastAPI) production configuration
############################################

# Core
env=prod
app_name=LMS API
api_prefix=/api/v1

# Database (MongoDB in docker-compose)
mongo_uri=mongodb://mongo:27017
mongo_db=lms

# Auth (CHANGE THIS in production)
jwt_secret=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
jwt_algorithm=HS256
access_token_expire_minutes=1440

# Payments / integrations (optional)
razorpay_key_id=
razorpay_key_secret=
razorpay_webhook_secret=
account_id=
client_id=
client_secret=

# CORS + links
cors_origins=https://learn.edu-mart.com
frontend_url=https://learn.edu-mart.com

# Email (optional)
sendgrid_api_key=
sendgrid_from_email=

# Business rules
platform_commission_percent=20.0
