############################################
# Docker Compose (production) environment
############################################

# Domain
DOMAIN=learn.edu-mart.com

# Frontend build-time env (baked into Vite build)
VITE_API_BASE_URL=https://learn.edu-mart.com/api/v1
VITE_WS_BASE_URL=wss://learn.edu-mart.com
VITE_API_MAX_CONCURRENCY=4

# MongoDB database name used by mongo container init
MONGO_DB=lms
