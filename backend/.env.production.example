APP_NAME=LMS API
ENV=prod
API_PREFIX=/api/v1

MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGO_DB=lms

JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

ACCOUNT_ID=
CLIENT_ID=
CLIENT_SECRET=

CORS_ORIGINS=https://learn.edu-mart.com
PLATFORM_COMMISSION_PERCENT=20

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
FRONTEND_URL=https://learn.edu-mart.com
